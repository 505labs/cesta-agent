# ============================================
# RoadTrip Co-Pilot — Environment Variables
# Copy to /opt/roadtrip/.env (VM) or project root (local)
# ============================================

# --- Wallet / Keys ---
PRIVATE_KEY=0x...           # Deployer private key
AGENT_PRIVATE_KEY=0x...     # Agent wallet (signs treasury txs)

# --- Circle ---
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# --- Arc Testnet (GroupTreasury chain) ---
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002
USDC_ADDRESS=0x3600000000000000000000000000000000000000
TREASURY_ADDRESS=            # Set after deploying GroupTreasury

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- Voice / Core VM ---
CORE_VM_URL=http://34.134.200.237
CORE_VM_API_KEY=
SESSION_MANAGER_URL=http://34.134.200.237:9001
VOICE_CHANNEL_URL=http://34.134.200.237:9000
VOICE_CHANNEL_PORT=9002

# --- Trip Memory ---
TRIP_MEMORY_DIR=./data/trip-memory

# --- 0G Storage (optional) ---
OG_STORAGE_ENABLED=false
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
OG_KV_NODE_URL=http://3.101.147.150:6789
OG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# --- 0G Compute (optional) ---
OG_COMPUTE_ENABLED=false
