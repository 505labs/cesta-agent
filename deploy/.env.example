# RoadTrip Co-Pilot — VM Environment Variables
# Copy to /opt/roadtrip/.env and fill in values.

# Voice channel port (9002 to avoid conflict with superapp on 9000)
VOICE_CHANNEL_PORT=9002

# Google Maps
GOOGLE_MAPS_API_KEY=

# Blockchain / Treasury
RPC_URL=
TREASURY_ADDRESS=
AGENT_PRIVATE_KEY=
CHAIN_ID=

# Trip Memory (local fallback if 0G not configured)
TRIP_MEMORY_DIR=/opt/roadtrip/data/trip-memory

# 0G Storage (optional)
OG_STORAGE_ENABLED=false
OG_RPC_URL=
OG_INDEXER_URL=
OG_KV_NODE_URL=
OG_FLOW_CONTRACT=

# 0G Compute (optional)
OG_COMPUTE_ENABLED=false
