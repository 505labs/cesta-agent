# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Orchestrator backend URL
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080

# Deployed GroupTreasury contract address
NEXT_PUBLIC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# USDC token address (on local Anvil or target chain)
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Chain RPC URL (default: local Anvil)
NEXT_PUBLIC_CHAIN_RPC_URL=http://127.0.0.1:8545

# WalletConnect Pay — get from dashboard.walletconnect.com
NEXT_PUBLIC_WC_PAY_APP_ID=your_wc_pay_app_id_here

# 0G Chain contract addresses (deployed on Galileo testnet)
NEXT_PUBLIC_AGENT_NFT_ADDRESS=
NEXT_PUBLIC_AGENT_REPUTATION_ADDRESS=
NEXT_PUBLIC_TRIP_REGISTRY_ADDRESS=

# 0G status indicators (set to "0g" when connected, "local"/"fallback" otherwise)
NEXT_PUBLIC_OG_STORAGE_MODE=local
NEXT_PUBLIC_OG_COMPUTE_MODE=fallback
NEXT_PUBLIC_OG_HAS_KEY=
