<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/wallet_header"
            style="@style/TextAppearance.RoadTrip.Display"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your crypto wallet connection"
            style="@style/TextAppearance.RoadTrip.Body"
            android:layout_marginBottom="@dimen/spacing_xxl" />

        <!-- Wallet card with gradient -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_wallet_card"
                android:padding="@dimen/spacing_xl">

                <!-- Status indicator row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_xl">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/primary"
                        android:importantForAccessibility="no" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!-- Status dot -->
                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:background="@drawable/bg_member_avatar" />

                    <TextView
                        android:id="@+id/txtAuthStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/authenticated"
                        android:textSize="@dimen/text_label"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Auth status label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_status_label"
                    style="@style/TextAppearance.RoadTrip.Label"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <!-- Wallet address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_input_dark"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/txtWalletAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textIsSelectable="true"
                        style="@style/TextAppearance.RoadTrip.Mono"
                        android:maxLines="1"
                        android:ellipsize="middle" />

                    <ImageView
                        android:id="@+id/btnCopyAddress"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/text_tertiary"
                        android:contentDescription="Copy address"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Security info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/outline"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/secondary"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Secured by SIWE"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign-In with Ethereum authentication"
                        style="@style/TextAppearance.RoadTrip.Caption" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
