<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Card Styles -->
    <style name="Widget.RoadTrip.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.RoadTrip.Card.Elevated" parent="Widget.RoadTrip.Card">
        <item name="cardBackgroundColor">@color/surface_elevated</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.RoadTrip.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.RoadTrip.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.RoadTrip.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- FAB -->
    <style name="Widget.RoadTrip.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/on_primary</item>
        <item name="fabCustomSize">64dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.RoadTrip.FAB</item>
    </style>

    <style name="ShapeAppearance.RoadTrip.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Base text appearance (required for dot-notation children) -->
    <style name="TextAppearance.RoadTrip" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.RoadTrip.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.RoadTrip.Headline">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.RoadTrip.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.RoadTrip.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.RoadTrip.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="TextAppearance.RoadTrip.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.RoadTrip.Mono">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Bottom Sheet Dialog -->
    <style name="Widget.RoadTrip.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.RoadTrip.BottomSheet</item>
        <item name="backgroundTint">@color/surface</item>
    </style>

    <style name="ShapeAppearance.RoadTrip.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_xl</item>
        <item name="cornerSizeTopRight">@dimen/radius_xl</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.RoadTrip.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="boxBackgroundColor">@color/surface_elevated</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <!-- Chip -->
    <style name="Widget.RoadTrip.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipCornerRadius">@dimen/radius_sm</item>
        <item name="chipMinHeight">28dp</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- Dialog -->
    <style name="Theme.RoadTrip.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_elevated</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Widget.RoadTrip.Dialog.Title</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.RoadTrip.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.RoadTrip.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.RoadTrip.Button.Dialog.Negative</item>
    </style>

    <style name="Widget.RoadTrip.Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textAppearance">@style/TextAppearance.RoadTrip.Title</item>
    </style>

    <style name="ShapeAppearance.RoadTrip.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_xl</item>
    </style>

    <style name="Widget.RoadTrip.Button.Dialog" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.RoadTrip.Button.Dialog.Negative" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
