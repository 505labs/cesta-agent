# TEE server URL
TEE_SERVER_URL=http://localhost:3000

# Demo merchant URL
MERCHANT_URL=http://localhost:3001

# Chain to use for payment
CHAIN=arc-testnet

# Arc wallet (for x402 payment signing)
ARC_WALLET_PRIVATE_KEY=0x...

# Hedera wallet (for x402 payment on Hedera)
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e...

# Amount to charge (in USD cents, e.g. 1000 = $10.00)
AMOUNT_USD_CENTS=1000

# LLM provider for browser-use agent: grok | anthropic | openai (default: grok)
LLM_PROVIDER=grok

# Grok (xAI) — https://console.x.ai
GROK_API_KEY=xai-...
GROK_MODEL=grok-4.20-0309-non-reasoning

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...
