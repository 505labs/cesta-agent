{
  "mcpServers": {
    "x402-pay": {
      "type": "stdio",
      "command": "/Users/luka/.pyenv/versions/tee-agent/bin/python",
      "args": ["mcp-servers/x402-pay/server.py"],
      "env": {}
    },
    "tee-web-agent": {
      "type": "stdio",
      "command": "/Users/luka/.pyenv/versions/tee-agent/bin/python",
      "args": ["mcp-servers/tee-web-agent/mcp_server.py"],
      "env": {}
    },
    "treasury": {
      "command": "bun",
      "args": ["mcp-servers/treasury/index.ts"],
      "env": {
        "RPC_URL": "${RPC_URL}",
        "TREASURY_ADDRESS": "${TREASURY_ADDRESS}",
        "AGENT_PRIVATE_KEY": "${AGENT_PRIVATE_KEY}",
        "CHAIN_ID": "${CHAIN_ID}"
      }
    },
    "trip-memory": {
      "command": "bun",
      "args": ["mcp-servers/trip-memory/index.ts"],
      "env": {
        "TRIP_MEMORY_DIR": "${TRIP_MEMORY_DIR}",
        "AGENT_PRIVATE_KEY": "${AGENT_PRIVATE_KEY}",
        "OG_STORAGE_ENABLED": "${OG_STORAGE_ENABLED}",
        "OG_RPC_URL": "${OG_RPC_URL}",
        "OG_INDEXER_URL": "${OG_INDEXER_URL}",
        "OG_KV_NODE_URL": "${OG_KV_NODE_URL}",
        "OG_FLOW_CONTRACT": "${OG_FLOW_CONTRACT}"
      }
    },
    "0g-compute": {
      "command": "bun",
      "args": ["mcp-servers/0g-compute/index.ts"],
      "env": {
        "AGENT_PRIVATE_KEY": "${AGENT_PRIVATE_KEY}",
        "OG_RPC_URL": "${OG_RPC_URL}",
        "OG_COMPUTE_ENABLED": "${OG_COMPUTE_ENABLED}"
      }
    },
    "voice-channel": {
      "command": "bun",
      "args": ["voice-channel/server.ts"],
      "env": {
        "VOICE_CHANNEL_PORT": "${VOICE_CHANNEL_PORT}"
      }
    }
  }
}
